# ============================================
# 善断计划 · 环境配置模板
# 复制此文件到 .env.dev / .env.test / .env.prod
# 然后填入实际值
# ============================================

# 运行环境: dev | test | prod
APP_ENV="dev"

# 数据库 URL（本地 SQLite）
DATABASE_URL="file:./data/judgment-trainer.db"

# NextAuth.js 会话加密密钥
# 生成: openssl rand -base64 32 或 node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# NextAuth URL（开发环境用 http://localhost:3000）
AUTH_URL="http://localhost:3000"

# AI 提供商: "deepseek" 或 "openai"
AI_PROVIDER="deepseek"
